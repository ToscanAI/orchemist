# Orchemist — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────

# Anthropic API key (required for default LLM executor)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenClaw Gateway (required for --mode openclaw) ─────────────────────

# URL of your OpenClaw gateway instance
OPENCLAW_GATEWAY_URL=http://localhost:18789

# Gateway auth token (from your openclaw.json config)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ── Optional — API keys & tokens ───────────────────────────────────────────

# GitHub token (required for auto-merge and PR creation features)
# GITHUB_TOKEN=ghp_...

# OpenAI API key (if using OpenAI executor instead of Anthropic)
# OPENAI_API_KEY=sk-...

# ── Optional — Engine config (ORCH_ prefix) ────────────────────────────────
# Any ORCH_<SECTION>_<KEY> var maps to config[section][key].
# See docs/api-reference.md for the full config schema.

# ORCH_DRY_RUN=1                          # Force dry-run mode globally
# ORCH_TEMPLATES_PATH=/extra/templates     # Colon-separated extra template dirs
# ORCH_DEFAULT_TEMPLATE=coding-pipeline-standard
# ORCH_LOGGING_LEVEL=DEBUG
# ORCH_MODELS_DEFAULT_TIER=sonnet
# ORCH_RETRY_MAX_RETRIES_DEFAULT=3
# ORCH_RESOURCES_DAILY_BUDGET_USD=10.00
# ORCH_QUEUE_MAX_WORKERS=4

# ── Optional — Notifications ───────────────────────────────────────────────

# NOTIFY_WEBHOOK_ENABLED=true
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/orchemist
# NOTIFY_WEBHOOK_SECRET=your-webhook-secret

# NOTIFY_TELEGRAM_ENABLED=true
# NOTIFY_TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# NOTIFY_TELEGRAM_CHAT_ID=987654321

# NOTIFY_OPENCLAW_ENABLED=true             # Route notifications via OpenClaw
# NOTIFY_QUIET_HOURS_ENABLED=true          # Suppress notifications during off-hours
# NOTIFY_QUIET_HOURS_START=23
# NOTIFY_QUIET_HOURS_END=8
# NOTIFY_QUIET_HOURS_TZ=Europe/Vienna

# ── Optional — Issue automation / webhooks ──────────────────────────────────

# ISSUE_TRIGGER_LABEL=orchemist
# WEBHOOK_PUBLIC_URL=https://your-domain.com/webhook

# ── Optional — Frontend (Next.js) ──────────────────────────────────────────

# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000    # Leave empty for same-origin
